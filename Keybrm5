-- CẤU HÌNH FIREBASE
local FIREBASE_URL = "https://keytokai-3ee28-default-rtdb.asia-southeast1.firebasedatabase.app/keys/"
local MAIN_SCRIPT_URL = "https://raw.githubusercontent.com/longhazem/BRM5-tokaihub/refs/heads/main/Tokaihub%20obf"

-- Hàm vạn năng để gửi yêu cầu (PATCH/GET)
local function requestData(url, method, body)
    local req = (syn and syn.request) or (http and http.request) or request or http_request
    if req then
        local response = req({
            Url = url,
            Method = method or "GET",
            Headers = {["Content-Type"] = "application/json"},
            Body = body and HttpService:JSONEncode(body) or nil
        })
        return response.Success, response.Body
    else
        -- Fallback cho GetAsync nếu không có hàm request (chỉ dùng được GET)
        if method == "GET" or not method then
            local s, b = pcall(function() return HttpService:GetAsync(url) end)
            return s, b
        end
    end
    return false, "Executor not supported"
end

local function getHWID()
    return tostring(game:GetService("RbxAnalyticsService"):GetClientId())
end

local function checkKeyOnFirebase(enteredKey)
    enteredKey = enteredKey:gsub("%s+", "") -- Xóa sạch khoảng trắng
    
    local success, response = requestData(FIREBASE_URL .. enteredKey .. ".json", "GET")
    
    if not success or response == "null" or response == nil or response == "" then
        return false, "Key does not exist!"
    end
    
    local data = HttpService:JSONDecode(response)
    local currentTime = os.time()
    
    -- 1. Kiểm tra hết hạn
    if data.expires_at and currentTime > data.expires_at then
        return false, "Key has expired!"
    end
    
    -- 2. Kiểm tra HWID
    local myHWID = getHWID()
    if data.hwid == "none" or data.hwid == nil then
        -- Key mới: Khóa HWID máy này lại
        requestData(FIREBASE_URL .. enteredKey .. ".json", "PATCH", {hwid = myHWID})
        return true, "Authorized!"
    elseif data.hwid ~= myHWID then
        return false, "Key is being used on another device!"
    end
    
    return true, "Success"
end

local function StartMainScript()
    local success, scriptContent = pcall(function()
        return game:HttpGet(MAIN_SCRIPT_URL)
    end)
    if success then
        loadstring(scriptContent)()
    else
        warn("Main script failed to load!")
    end
end


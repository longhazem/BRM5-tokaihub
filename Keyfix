LoginBtn.MouseButton1Click:Connect(function()
    local key = Input.Text:gsub("%s+", "")
    if key == "" then Status.Text = "Vui lòng nhập mã!"; return end
    
    Status.Text = "Đang xác thực..."
    Status.TextColor3 = Color3.new(1, 1, 1)
    
    local success, response = safeRequest(FIREBASE_URL .. key .. ".json", "GET")
    
    if success and response ~= "null" and response ~= nil then
        local data = HttpService:JSONDecode(response)
        local myHWID = getHWID()
        
        -- Kiểm tra hết hạn
        if data.expires_at and os.time() > data.expires_at then
            Status.Text = "Key đã hết hạn!"
            Status.TextColor3 = Color3.new(1, 0, 0)
            return
        end
        
        -- Kiểm tra HWID
        if data.hwid == "none" or data.hwid == nil then
            safeRequest(FIREBASE_URL .. key .. ".json", "PATCH", {hwid = myHWID})
        elseif data.hwid ~= myHWID then
            Status.Text = "Key đã bị khóa thiết bị!"
            Status.TextColor3 = Color3.new(1, 0, 0)
            return
        end
        
        Status.Text = "THÀNH CÔNG! ĐANG TẢI SCRIPT..."
        Status.TextColor3 = Color3.new(0, 1, 0.5)
        Stroke.Color = Color3.new(0, 1, 0.5)
        task.wait(1)
        sg:Destroy()
        
        -- Tải Script chính
        local s2, content = pcall(function() return game:HttpGet(MAIN_SCRIPT_URL) end)
        if s2 then loadstring(content)() else warn("Lỗi tải Script GitHub!") end
    else
        Status.Text = "Key không hợp lệ!"
        Status.TextColor3 = Color3.new(1, 0.3, 0.3)
        Stroke.Color = Color3.new(1, 0, 0)
    end
end)


-- HÀM HỆ THỐNG
-- ==========================================
local function getHWID()
    return tostring(game:GetService("RbxAnalyticsService"):GetClientId())
end

local function safeRequest(url, method, body)
    local req = request or http_request or syn_request or (http and http.request)
    if req then
        local res = req({
            Url = url,
            Method = method or "GET",
            Headers = {["Content-Type"] = "application/json"},
            Body = body and HttpService:JSONEncode(body) or nil
        })
        return res.Success, res.Body
    else
        if method == "GET" or not method then
            local success, res = pcall(function() return HttpService:GetAsync(url) end)
            return success, res
        end
    end
    return false, "Executor not supported"
end


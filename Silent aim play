    ShowFov = true,
    FovRadius = 180
}

-- Khởi tạo vòng FOV (Không có ruột)
local Drawings = {FovOutline = nil}
function AddDrawing(Type, Properties)
    local DrawingObject = Drawing.new(Type)
    for Property, Value in pairs(Properties) do
        DrawingObject[Property] = Value
    end
    return DrawingObject
end

Drawings.FovOutline = AddDrawing('Circle', {
    Visible = Options.ShowFov, 
    Filled = false, -- Không có ruột
    Position = Camera.ViewportSize / 2, 
    Radius = Options.FovRadius, 
    Thickness = 1.5, 
    Color = Color3.new(1, 1, 1)
})

-- Hàm liên tục cập nhật vị trí và kích thước FOV theo UI
RunService.RenderStepped:Connect(function()
    if Drawings.FovOutline then
        Drawings.FovOutline.Position = Camera.ViewportSize / 2
        Drawings.FovOutline.Radius = Options.FovRadius
        Drawings.FovOutline.Visible = Options.ShowFov
    end
end)


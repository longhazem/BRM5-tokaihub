-- Logic Slider tối ưu cho Mobile
local function UpdateSlider(input)
    local sizeX = math.clamp((input.Position.X - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
    SliderFill.Size = UDim2.new(sizeX, 0, 1, 0)
    
    local val = math.floor(sizeX * 500)
    if val < 5 then val = 5 end
    Options.FovRadius = val
    SliderLabel.Text = "FOV Size: " .. val
end

local isSiding = false
SliderBG.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isSiding = true
        UpdateSlider(input)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isSiding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        UpdateSlider(input)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isSiding = false
    end
end)

-- Draggable Menu
local dragToggle, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not isSiding then
        dragToggle = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragToggle = false
    end
end)

---------------------------------------------------------
-- LOGIC SILENT AIM
---------------------------------------------------------
local Functions = {
    GetClients = filtergc('function', {Name = 'GetClients', Constants = {'Clients'}}, false),
    GetMuzzleCFrame = filtergc('function', {Name = 'GetMuzzleCFrame'}, true),
    GetRecoil = filtergc('function', {Name = 'getRecoil'}, true)
}

local ClientService = nil

for _, Function in pairs(Functions.GetClients) do
    local Info = getinfo(Function)
    if not Info.source:find('ClientService') then continue end
    Functions.GetClients = Function
end

local OldClients; OldClients = hookfunction(Functions.GetClients, function(Self)
    ClientService = Self; return OldClients(Self)
end)

function GetClosest()
    local ClosestPlayer, ClosestData, ClosestDistance = nil, nil, math.huge
    if not ClientService then return end

    for Player, Data in pairs(ClientService.Clients) do
        if Player == LocalPlayer then continue end
        if not Data.Actor or not Data.Actor.Alive then continue end
        if Data.Squad == ClientService.LocalClient.Squad then continue end

        local Position, OnScreen = Camera:WorldToViewportPoint(Data.Actor.Parts.Head.Position)
        if not OnScreen then continue end

        local Distance = (Vector2.new(Position.X, Position.Y) - (Camera.ViewportSize / 2)).Magnitude
        if Distance > Options.FovRadius or Distance > ClosestDistance then continue end

        ClosestPlayer = Player; ClosestData = Data; ClosestDistance = Distance
    end
    return ClosestPlayer, ClosestData
end

local OldMuzzle; OldMuzzle = hookfunction(Functions.GetMuzzleCFrame, function(Self, Cast)
    local Origin, Barrel, CameraCF = OldMuzzle(Self, Cast)
    if Options.SilentAim and not Cast and Origin then
        local Player, Data = GetClosest()
        if Player then
            return CFrame.new(Origin.Position, Data.Actor.Parts.Head.Position), Barrel, CameraCF
        end
    end
    return Origin, Barrel, CameraCF
end)

local OldRecoil; OldRecoil = hookfunction(Functions.GetRecoil, function(...)
    local Args = {...}
    if Options.SilentAim and Args[1] then
        Args[1]['Barrel_Spread'] = 0; Args[1]['RecoilForce_Tap'] = 0
    end
    return OldRecoil(unpack(Args))
end)

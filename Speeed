-- Cấu hình
getgenv().WalkSpeedEnabled = true
getgenv().CustomSpeed = 50 -- Tốc độ bạn muốn

local CharControllerClass = nil

-- 1. Tìm module qua getloadedmodules (Cách an toàn)
if getloadedmodules then
    for _, mod in ipairs(getloadedmodules()) do
        if mod.Name == "CharacterController" then
            CharControllerClass = require(mod)
            break
        end
    end
end

-- 2. Tìm module qua getgc (Cách mạnh mẽ nhất nếu cách 1 thất bại)
if not CharControllerClass and getgc then
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" and rawget(v, "Update") and rawget(v, "_exhaust") then
            CharControllerClass = v
            break
        end
    end
end

if CharControllerClass then
    -- Lưu lại các hàm gốc để không bị lỗi khi execute nhiều lần
    if not getgenv().OldCharUpdate then
        getgenv().OldCharUpdate = CharControllerClass.Update
        getgenv().OldCharExhaust = CharControllerClass._exhaust
    end

    -- Ghi đè hàm Update
    CharControllerClass.Update = function(self, ...)
        -- Quan trọng: Cho game tính toán mọi thứ trước
        local result = getgenv().OldCharUpdate(self, ...)

        -- Sau đó ta ép tốc độ của ta vào để game không kịp ghi đè lại
        if getgenv().WalkSpeedEnabled then
            -- Tác động trực tiếp vào Humanoid nếu có
            if self._humanoid then
                self._humanoid.WalkSpeed = getgenv().CustomSpeed
            end
            
            -- Tác động vào các biến nội bộ của BRM5
            self._speed = getgenv().CustomSpeed
            self._walkSpeed = getgenv().CustomSpeed
            self._sprintSpeed = getgenv().CustomSpeed * 1.5
        end

        return result
    end

    -- Ghi đè hàm Exhaust để có vô hạn thể lực (chạy không mệt)
    if getgenv().OldCharExhaust then
        CharControllerClass._exhaust = function(self, ...)
            if getgenv().WalkSpeedEnabled then
                -- Bỏ qua việc trừ thể lực
                return
            end
            return getgenv().OldCharExhaust(self, ...)
        end
    end

    print("✅ Đã kích hoạt Walkspeed thành công! (Bản nâng cao)")
else
    warn("❌ Vẫn không tìm thấy CharacterController! Hãy thử dùng Executor khác mạnh hơn (như Krnl, Synapse, Fluxus, Delta...).")
end

-- Cấu hình
getgenv().WalkSpeedEnabled = true
getgenv().SpeedValue = 60 -- Chỉnh tốc độ ở đây (Mặc định game là 16)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Hàm tìm kiếm Module từ script gốc của bạn
local function findModule(name)
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("ModuleScript") and v.Name == name then
            return v
        end
    end
    return nil
end

-- Lấy CharacterController bằng phương pháp chính xác từ file gốc
local CharModule = findModule("CharacterController")
local CharacterController = nil

if CharModule then
    CharacterController = require(CharModule)
end

-- Vòng lặp ép tốc độ cực mạnh (Mỗi frame)
local SpeedConnection
SpeedConnection = RunService.Stepped:Connect(function()
    if not getgenv().WalkSpeedEnabled then
        SpeedConnection:Disconnect()
        return
    end

    pcall(function()
        -- 1. Ép thông qua Humanoid
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = getgenv().SpeedValue
        end

        -- 2. Ép thông qua Module nội bộ của game (Quan trọng nhất)
        if CharacterController then
            -- Ép các biến vận tốc
            CharacterController._speed = getgenv().SpeedValue
            CharacterController._walkSpeed = getgenv().SpeedValue
            CharacterController._sprintSpeed = getgenv().SpeedValue * 1.2
            
            -- Ép thể lực để không bao giờ mệt
            if CharacterController._stamina then
                CharacterController._stamina = 100
            end
            if CharacterController._isExhausted then
                CharacterController._isExhausted = false
            end
        end
    end)
end)

-- Thông báo
if CharModule then
    print("✅ Đã tìm thấy CharacterController và kích hoạt Walkspeed!")
else
    warn("⚠️ Không tìm thấy module gốc, đang chạy chế độ ép Humanoid dự phòng.")
end

-- Cấu hình
getgenv().WalkSpeedEnabled = true
getgenv().CustomSpeed = 60 -- Bạn có thể tăng lên 100 nếu muốn cực nhanh

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Hàm tìm Module Controller
local function GetCharController()
    if getloadedmodules then
        for _, mod in ipairs(getloadedmodules()) do
            if mod.Name == "CharacterController" then
                return require(mod)
            end
        end
    end
    -- Fallback nếu không có getloadedmodules
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" and rawget(v, "Update") and rawget(v, "_exhaust") then
            return v
        end
    end
    return nil
end

local CharController = GetCharController()

-- Vòng lặp ép tốc độ (Force Speed)
-- Chúng ta dùng Heartbeat để ép giá trị sau khi game đã tính toán xong
local SpeedLoop
SpeedLoop = RunService.Heartbeat:Connect(function()
    if not getgenv().WalkSpeedEnabled then 
        SpeedLoop:Disconnect()
        return 
    end

    pcall(function()
        local Character = LocalPlayer.Character
        if Character and Character:FindFirstChild("Humanoid") then
            -- 1. Ép trực tiếp vào Humanoid
            Character.Humanoid.WalkSpeed = getgenv().CustomSpeed
            
            -- 2. Ép vào Module CharacterController của BRM5
            if CharController then
                -- Ép các biến nội bộ mà game dùng để kiểm tra
                CharController._speed = getgenv().CustomSpeed
                CharController._walkSpeed = getgenv().CustomSpeed
                CharController._sprintSpeed = getgenv().CustomSpeed
                
                -- Ngăn chặn việc bị kiệt sức (Exhaust)
                if CharController._stamina then
                    CharController._stamina = 100
                end
                if CharController._isExhausted then
                    CharController._isExhausted = false
                end
            end
        end
    end)
end)

-- Hook thêm vào hàm Update để chặn các script khác reset tốc độ
if CharController and not getgenv().OldUpdate then
    getgenv().OldUpdate = CharController.Update
    CharController.Update = function(self, ...)
        local res = getgenv().OldUpdate(self, ...)
        if getgenv().WalkSpeedEnabled then
            self._speed = getgenv().CustomSpeed
        end
        return res
    end
end

print("🚀 Đã kích hoạt Ép Tốc Độ! Hãy thử di chuyển xem sao.")
